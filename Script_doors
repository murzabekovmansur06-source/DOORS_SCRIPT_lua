-- ESP СИСТЕМА (С ТРОЙНЫМ ДЕТЕКТОРОМ МОНСТРОВ)
-- ============================================================================
local highlights = {}
local ESP_RADIUS = 60

-- Тройной детектор монстров
local function isMonster(obj)
    local name = obj.Name:lower()
    
    -- Метод 1: По имени
    local monsterNames = {"rush", "ambush", "figure", "seek", "screech", "halt", "eyes", "timothy", "jack"}
    for _, mn in ipairs(monsterNames) do
        if name:find(mn) then return true, mn end
    end
    
    -- Метод 2: По звуку (если у монстра есть звуковой компонент)
    for _, child in ipairs(obj:GetChildren()) do
        if child:IsA("Sound") and child.IsLoaded then
            for _, mn in ipairs(monsterNames) do
                if child.Name:lower():find(mn) or child.SoundId:lower():find(mn) then
                    return true, mn .. "_sound"
                end
            end
        end
    end
    
    -- Метод 3: По атрибутам (некоторые монстры имеют специфичные атрибуты)
    local attrs = {"IsRush", "IsAmbush", "IsFigure", "IsSeek", "IsScreech"}
    for _, attr in ipairs(attrs) do
        pcall(function()
            if obj:GetAttribute(attr) == true then
                return true, attr:lower()
            end
        end)
    end
    
    return false, nil
end

local function updateESP()
    local hrp = getHRP()
    if not hrp then return end
    local playerPos = hrp.Position
    
    for obj, h in pairs(highlights) do
        if not obj.Parent then
            pcall(function() h:Destroy() end)
            highlights[obj] = nil
        end
    end
    
    local function hl(obj, color)
        if not obj or highlights[obj] then return end
        local pos = obj:IsA("Model") and obj:GetPivot().Position or (obj:IsA("BasePart") and obj.Position or nil)
        if not pos or (playerPos - pos).Magnitude > ESP_RADIUS then return end
        local h = Instance.new("Highlight")
        h.Name = "DoorsESP"
        h.FillColor = color
        h.FillTransparency = 0.5
        h.OutlineColor = Color3.new(1,1,1)
        h.Parent = obj
        highlights[obj] = h
    end
    
    if _G.DoorsSettings.EntityESP then
        for _, v in ipairs(ws:GetDescendants()) do
            local found, monName = isMonster(v)
            if found then
                -- Разные цвета для разных типов
                local color = Color3.fromRGB(255, 0, 0) -- красный по умолчанию
                if monName:find("rush") then color = Color3.fromRGB(255, 100, 0)
                elseif monName:find("ambush") then color = Color3.fromRGB(255, 0, 100)
                elseif monName:find("figure") then color = Color3.fromRGB(200, 0, 0)
                elseif monName:find("seek") then color = Color3.fromRGB(255, 50, 50)
                elseif monName:find("screech") then color = Color3.fromRGB(150, 0, 255)
                end
                hl(v, color)
            end
        end
    end
    
    if _G.DoorsSettings.ItemESP then
        for _, v in ipairs(ws:GetDescendants()) do
            for _, item in ipairs({"Key","Gold","Coin","Battery","Lockpick","Vitamins","Crucifix","Candle"}) do
                if v.Name:find(item) then hl(v, Color3.fromRGB(0,255,200)) break end
            end
        end
    end
    
    if _G.DoorsSettings.DoorESP then
        for _, v in ipairs(ws:GetDescendants()) do
            if v:IsA("BasePart") and v.Name:find("Door") and not v.Name:find("DoorFrame") then
                hl(v, Color3.fromRGB(255,255,0))
            end
        end
    end
end

-- ============================================================================
-- АВТО-ВЗАИМОДЕЙСТВИЕ (ИСПРАВЛЕНО)
-- ============================================================================
local excludedNames = {"Wardrobe", "Closet", "Bed", "Wardroba", "Шкаф", "Кровать"}
local function isExcluded(obj)
    local str = (obj.Name .. (obj.Parent and obj.Parent.Name or "")):lower()
    for _, ex in ipairs(excludedNames) do
        if str:find(ex:lower()) then return true end
    end
    return false
end

local function autoInteract()
    local hrp = getHRP()
    if not hrp then return end
    local playerPos = hrp.Position
    
    for _, v in ipairs(ws:GetDescendants()) do
        if v:IsA("ProximityPrompt") and v.Enabled then
            if isExcluded(v) or isExcluded(v.Parent) then continue end
            
            local promptParent = v.Parent
            local pos = nil
            if promptParent then
                pos = promptParent:IsA("BasePart") and promptParent.Position 
                    or (promptParent:IsA("Model") and promptParent:GetPivot().Position)
            end
            
            if pos and (playerPos - pos).Magnitude < 15 then
                pcall(function() 
                    fireproximityprompt(v) 
                end)
            end
        end
    end
end

