local function getChar() return p.Character end
local function getHRP() local c = getChar() return c and c:FindFirstChild("HumanoidRootPart") end
local function getHum() local c = getChar() return c and c:FindFirstChildOfClass("Humanoid") end

-- ============================================================================
-- PLAVNY WALKSPEED
-- ============================================================================
local speedDirection = 1
local function smoothWalkSpeed()
    task.spawn(function()
        while _G.DoorsSettings.SpeedBoost do
            local hum = getHum()
            if hum then
                local target = _G.DoorsSettings.SpeedValue + (4 * speedDirection)
                ts:Create(hum, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {WalkSpeed = target}):Play()
                speedDirection = speedDirection * -1
            end
            task.wait(1)
        end
        local hum = getHum()
        if hum then ts:Create(hum, TweenInfo.new(0.5), {WalkSpeed = 16}):Play() end
    end)
end

-- ============================================================================
-- NOCLIP С ЛУЧОМ
-- ============================================================================
local function teleportOnRay()
    local char = getChar()
    if not char then return end
    local hrp = getHRP()
    if not hrp then return end
    local rayResult = ws:Raycast(ws.CurrentCamera.CFrame.Position, ws.CurrentCamera.CFrame.LookVector * 500, RaycastParams.new():SetFilterDescendantsInstances({char}))
    if rayResult then hrp.CFrame = CFrame.new(rayResult.Position + rayResult.Normal * 3) end
end

